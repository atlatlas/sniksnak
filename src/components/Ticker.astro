---
import { t, type Locale } from '../i18n/translations';

interface Props {
    headlines: string[];
    locale: Locale;
}

const { headlines, locale } = Astro.props;
const strings = t(locale);
---

<div class="ticker">
    {headlines.length > 0 ? (
        <div class="ticker-content">
            {headlines.map((h, i) => (
                <>
                    <span class="ticker-item">{h}</span>
                    {i < headlines.length - 1 && <span class="ticker-dot">&bull;</span>}
                </>
            ))}
        </div>
    ) : (
        <div class="ticker-content ticker-empty">
            {strings.ticker.empty}
        </div>
    )}
</div>
