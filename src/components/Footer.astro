---
const categories = [
    { label: 'Binnenland', href: '/rubriek/binnenland' },
    { label: 'Buitenland', href: '/rubriek/buitenland' },
    { label: 'Tech', href: '/rubriek/tech' },
    { label: 'Sport', href: '/rubriek/sport' },
    { label: 'Column', href: '/rubriek/column' },
];
---

<footer class="site-footer">
    <div class="footer-inner">
        <div class="footer-brand">
            <div class="logo">
                <a href="/">
                    <span class="logo-icon">S</span>
                    <span class="logo-text">SNIKSNAK</span>
                </a>
            </div>
            <p>Nieuws dat je nodig hebt, maar niet verdiend hebt.</p>
        </div>
        <div class="footer-links">
            <div class="footer-col">
                <h4>Rubrieken</h4>
                {categories.map(c => (
                    <a href={c.href}>{c.label}</a>
                ))}
            </div>
            <div class="footer-col">
                <h4>Over ons</h4>
                <a href="#">Redactie</a>
                <a href="#">Contact</a>
                <a href="#">Adverteren</a>
            </div>
            <div class="footer-col">
                <h4>Legaal</h4>
                <a href="#">Privacy</a>
                <a href="#">Voorwaarden</a>
                <a href="#">Cookies</a>
            </div>
        </div>
    </div>
    <div class="footer-bottom">
        <p>&copy; {new Date().getFullYear()} Sniksnak. Alle rechten voorbehouden. Gebruikersrechten verboden.</p>
    </div>
</footer>
