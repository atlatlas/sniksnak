---
import { t, type Locale } from '../i18n/translations';

interface Props {
    locale: Locale;
}

const { locale } = Astro.props;
const strings = t(locale);
const prefix = locale === 'en' ? '' : '/nl';
---

<footer class="site-footer">
    <div class="footer-inner">
        <div class="footer-brand">
            <div class="logo">
                <a href={locale === 'en' ? '/' : '/nl/'}>
                    <span class="logo-icon">S</span>
                    <span class="logo-text">SNIKSNAK</span>
                </a>
            </div>
            <p>{strings.footer.tagline}</p>
        </div>
        <div class="footer-links">
            <div class="footer-col">
                <h4>{strings.footer.categories}</h4>
                <a href={`${prefix}/rubriek/binnenland`}>{strings.nav.domestic}</a>
                <a href={`${prefix}/rubriek/buitenland`}>{strings.nav.world}</a>
                <a href={`${prefix}/rubriek/tech`}>{strings.nav.tech}</a>
                <a href={`${prefix}/rubriek/sport`}>{strings.nav.sports}</a>
                <a href={`${prefix}/rubriek/column`}>{strings.nav.column}</a>
            </div>
            <div class="footer-col">
                <h4>{strings.footer.aboutUs}</h4>
                <a href="#">{strings.footer.editorial}</a>
                <a href="#">{strings.footer.contact}</a>
                <a href="#">{strings.footer.advertise}</a>
            </div>
            <div class="footer-col">
                <h4>{strings.footer.legal}</h4>
                <a href="#">{strings.footer.privacy}</a>
                <a href="#">{strings.footer.terms}</a>
                <a href="#">{strings.footer.cookies}</a>
            </div>
        </div>
    </div>
    <div class="footer-bottom">
        <p>&copy; {new Date().getFullYear()} Sniksnak. {strings.footer.copyright}</p>
    </div>
</footer>
