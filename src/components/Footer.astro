---
import { t, type Locale } from '../i18n/translations';

interface Props {
    locale: Locale;
}

const { locale } = Astro.props;
const strings = t(locale);
const base = import.meta.env.BASE_URL;
const prefix = `${base}${locale === 'en' ? '' : 'nl/'}`;
---

<footer class="site-footer">
    <div class="footer-inner">
        <div class="footer-brand">
            <div class="logo">
                <a href={`${base}${locale === 'en' ? '' : 'nl/'}`}>
                    <span class="logo-icon">S</span>
                    <span class="logo-text">SNIKSNAK</span>
                </a>
            </div>
            <p>{strings.footer.tagline}</p>
        </div>
        <div class="footer-links">
            <div class="footer-col">
                <h4>{strings.footer.categories}</h4>
                <a href={`${prefix}rubriek/binnenland`}>{strings.nav.domestic}</a>
                <a href={`${prefix}rubriek/buitenland`}>{strings.nav.world}</a>
                <a href={`${prefix}rubriek/tech`}>{strings.nav.tech}</a>
                <a href={`${prefix}rubriek/sport`}>{strings.nav.sports}</a>
                <a href={`${prefix}rubriek/column`}>{strings.nav.column}</a>
            </div>
            <div class="footer-col">
                <h4><a href={`${base}about`}>{strings.footer.aboutUs}</a></h4>
                <a href={`${base}editorial`}>{strings.footer.editorial}</a>
            </div>
            <div class="footer-col">
                <h4>{strings.footer.legal}</h4>
                <a href={`${base}privacy`}>{strings.footer.privacy}</a>
                <a href={`${base}terms`}>{strings.footer.terms}</a>
                <a href={`${base}cookies`}>{strings.footer.cookies}</a>
            </div>
        </div>
    </div>
    <div class="footer-bottom">
        <p>&copy; {new Date().getFullYear()} Sniksnak. {strings.footer.copyright}</p>
    </div>
</footer>
