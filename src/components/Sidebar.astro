---
import { t, type Locale } from '../i18n/translations';

interface Article {
    title: string;
    slug: string;
}

interface Props {
    recentArticles: Article[];
    locale: Locale;
}

const { recentArticles, locale } = Astro.props;
const strings = t(locale);
const base = import.meta.env.BASE_URL;
const prefix = `${base}${locale === 'en' ? '' : 'nl'}`;
---

<aside class="sidebar">
    <div class="sidebar-section">
        <h3 class="sidebar-title">{strings.sidebar.trending}</h3>
        {recentArticles.length > 0 ? (
            <ol class="trending-list">
                {recentArticles.slice(0, 5).map(a => (
                    <li><a href={`${prefix}/artikels/${a.slug}`}>{a.title}</a></li>
                ))}
            </ol>
        ) : (
            <p class="trending-empty">{strings.sidebar.trendingEmpty}</p>
        )}
    </div>

    <div class="sidebar-section newsletter-box">
        <h3 class="sidebar-title">{strings.sidebar.newsletterTitle}</h3>
        <p>{strings.sidebar.newsletterDesc}</p>
        <form class="newsletter-form" id="newsletterForm">
            <input type="email" placeholder={strings.sidebar.newsletterPlaceholder} required>
            <button type="submit">{strings.sidebar.newsletterButton}</button>
        </form>
        <p class="newsletter-note">{strings.sidebar.newsletterNote}</p>
    </div>

    <div class="sidebar-section quote-box">
        <blockquote>{strings.sidebar.quote}</blockquote>
        <cite>{strings.sidebar.quoteAuthor}</cite>
    </div>
</aside>

<script define:vars={{ subscribedMsg: strings.toast.subscribed }}>
    document.getElementById('newsletterForm')?.addEventListener('submit', (e) => {
        e.preventDefault();
        const input = e.target.querySelector('input');
        if (input && input.value) {
            window.showToast(subscribedMsg);
            input.value = '';
        }
    });
</script>
