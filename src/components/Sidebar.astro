---
interface Article {
    title: string;
    slug: string;
}

interface Props {
    recentArticles: Article[];
}

const { recentArticles } = Astro.props;
---

<aside class="sidebar">
    <div class="sidebar-section">
        <h3 class="sidebar-title">Trending</h3>
        {recentArticles.length > 0 ? (
            <ol class="trending-list">
                {recentArticles.slice(0, 5).map(a => (
                    <li><a href={`/artikels/${a.slug}`}>{a.title}</a></li>
                ))}
            </ol>
        ) : (
            <p class="trending-empty">Nog geen artikelen.</p>
        )}
    </div>

    <div class="sidebar-section newsletter-box">
        <h3 class="sidebar-title">Blijf op de hoogte</h3>
        <p>Elke vrijdag het beste sarcasme in je inbox. Geen spam, beloofd.</p>
        <form class="newsletter-form" id="newsletterForm">
            <input type="email" placeholder="jouw@email.nl" required>
            <button type="submit">Aanmelden</button>
        </form>
        <p class="newsletter-note">Afmelden kan altijd. Je hebt waarschijnlijk toch niets beters te doen.</p>
    </div>

    <div class="sidebar-section quote-box">
        <blockquote>
            "Ik lees niet omdat ik het leuk vind. Ik lees omdat ik op de trein zit en geen bereik heb."
        </blockquote>
        <cite>&mdash; Echte Nederlander</cite>
    </div>
</aside>

<script>
    document.getElementById('newsletterForm')?.addEventListener('submit', (e) => {
        e.preventDefault();
        const input = (e.target as HTMLFormElement).querySelector('input');
        if (input && input.value) {
            (window as any).showToast('Je bent aangemeld! Bereid je voor op de waarheid.');
            input.value = '';
        }
    });
</script>
