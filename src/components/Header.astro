---
const categories = [
    { label: 'Voorpagina', href: '/' },
    { label: 'Binnenland', href: '/rubriek/binnenland' },
    { label: 'Buitenland', href: '/rubriek/buitenland' },
    { label: 'Tech', href: '/rubriek/tech' },
    { label: 'Sport', href: '/rubriek/sport' },
    { label: 'Column', href: '/rubriek/column' },
];
---

<header class="site-header">
    <div class="header-inner">
        <div class="logo">
            <a href="/">
                <span class="logo-icon">S</span>
                <span class="logo-text">SNIKSNAK</span>
            </a>
        </div>
        <nav class="desktop-nav">
            {categories.map(c => (
                <a href={c.href} class="nav-link">{c.label}</a>
            ))}
        </nav>
        <div class="header-actions">
            <button class="search-toggle" id="searchToggle" aria-label="Zoeken">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            </button>
            <button class="mobile-menu-toggle" id="mobileMenuToggle" aria-label="Menu">
                <span></span><span></span><span></span>
            </button>
        </div>
    </div>
</header>

<div class="mobile-nav-overlay" id="mobileNavOverlay">
    <nav class="mobile-nav">
        {categories.map(c => (
            <a href={c.href} class="mobile-nav-link">{c.label}</a>
        ))}
    </nav>
</div>
