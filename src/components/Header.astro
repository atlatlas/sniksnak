---
import { t, type Locale, switchLocalePath } from '../i18n/translations';

interface Props {
  locale: Locale;
  currentPath: string;
}

const { locale, currentPath } = Astro.props;
const strings = t(locale);
const otherLocale = locale === 'en' ? 'nl' : 'en';
const base = import.meta.env.BASE_URL;
const prefix = `${base}${locale === 'en' ? '' : 'nl/'}`;
const switchPath = `${base}${switchLocalePath(currentPath, otherLocale, locale).replace(/^\//, '')}`;
---

<header class="site-header">
    <div class="header-inner">
        <div class="logo">
            <a href={prefix}>
                <span class="logo-icon">S</span>
                <span class="logo-text">SNIKSNAK</span>
            </a>
        </div>
        <nav class="desktop-nav">
            <a href={prefix} class="nav-link">{strings.nav.home}</a>
            <a href={`${prefix}rubriek/binnenland`} class="nav-link">{strings.nav.domestic}</a>
            <a href={`${prefix}rubriek/buitenland`} class="nav-link">{strings.nav.world}</a>
            <a href={`${prefix}rubriek/tech`} class="nav-link">{strings.nav.tech}</a>
            <a href={`${prefix}rubriek/sport`} class="nav-link">{strings.nav.sports}</a>
            <a href={`${prefix}rubriek/column`} class="nav-link">{strings.nav.column}</a>
            <a href={switchPath} class="nav-link" style="opacity:0.6">{locale === 'en' ? 'NL' : 'EN'}</a>
        </nav>
        <div class="header-actions">
            <button class="theme-toggle" id="themeToggle" aria-label="Toggle theme">
                <svg class="theme-icon-light" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
                <svg class="theme-icon-dark" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
            </button>
            <button class="mobile-menu-toggle" id="mobileMenuToggle" aria-label="Menu">
                <span></span><span></span><span></span>
            </button>
        </div>
    </div>
</header>

<div class="mobile-nav-overlay" id="mobileNavOverlay">
    <nav class="mobile-nav">
        <a href={prefix} class="mobile-nav-link">{strings.nav.home}</a>
        <a href={`${prefix}rubriek/binnenland`} class="mobile-nav-link">{strings.nav.domestic}</a>
        <a href={`${prefix}rubriek/buitenland`} class="mobile-nav-link">{strings.nav.world}</a>
        <a href={`${prefix}rubriek/tech`} class="mobile-nav-link">{strings.nav.tech}</a>
        <a href={`${prefix}rubriek/sport`} class="mobile-nav-link">{strings.nav.sports}</a>
        <a href={`${prefix}rubriek/column`} class="mobile-nav-link">{strings.nav.column}</a>
        <a href={switchPath} class="mobile-nav-link" style="opacity:0.6">{locale === 'en' ? 'NL' : 'EN'}</a>
    </nav>
</div>
