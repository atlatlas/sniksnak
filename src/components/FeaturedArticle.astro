---
import { t, type Locale } from '../i18n/translations';

interface Props {
    title: string;
    slug: string;
    category: string;
    date: Date;
    author: string;
    excerpt: string;
    image?: string;
    readTime?: number;
    locale: Locale;
}

const { title, slug, category, date, author, excerpt, image, readTime, locale } = Astro.props;
const strings = t(locale);

const categoryLabels: Record<string, Record<string, string>> = {
    en: { binnenland: 'Domestic', buitenland: 'World', tech: 'Tech', sport: 'Sports', column: 'Column' },
    nl: { binnenland: 'Binnenland', buitenland: 'Buitenland', tech: 'Tech', sport: 'Sport', column: 'Column' },
};

const base = import.meta.env.BASE_URL;
const prefix = `${base}${locale === 'en' ? '' : 'nl'}`;
const formattedDate = date.toLocaleDateString(locale, { day: 'numeric', month: 'long', year: 'numeric' });
const initials = author.split(' ').map(n => n[0]).join('').toUpperCase().slice(0, 2);
const categoryLabel = categoryLabels[locale]?.[category] || category;
---

<article class="featured-article">
    <a href={`${prefix}/artikels/${slug}`} class="featured-image">
        {image ? (
            <img src={`${base}${image.replace(/^\//, '')}`} alt={title} loading="lazy" />
        ) : (
            <div class="placeholder-img" style="color:rgba(255,255,255,0.15)">
                <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round"><rect x="3" y="3" width="18" height="18" rx="2"/><circle cx="8.5" cy="8.5" r="1.5"/><path d="M21 15l-5-5L5 21"/></svg>
            </div>
        )}
        <span class={`category-tag tag-${category}`}>{categoryLabel}</span>
    </a>
    <div class="featured-content">
        <div class="article-meta">
            <time datetime={date.toISOString()}>{formattedDate}</time>
            {readTime && <span class="read-time">{readTime} {strings.featured.readTime}</span>}
        </div>
        <h1><a href={`${prefix}/artikels/${slug}`}>{title}</a></h1>
        <p class="featured-excerpt">{excerpt}</p>
        <div class="author">
            <div class="author-avatar">{initials}</div>
            <span>{author}</span>
        </div>
    </div>
</article>
