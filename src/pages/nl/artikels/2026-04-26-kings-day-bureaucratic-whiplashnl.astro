---
const base = import.meta.env.BASE_URL;
const destination = `${base}nl/artikels/2026-04-26-kings-night-bureaucratic-whiplashnl/`;
const refreshContent = `0; url=${destination}`;
---
<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Doorverwijzen...</title>
    <meta http-equiv="refresh" content={refreshContent}>
    <link rel="canonical" href={destination}>
</head>
<body>
    <p>Doorverwezen naar <a href={destination}>het gecorrigeerde artikel</a>...</p>
</body>
</html>
