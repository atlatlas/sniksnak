---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import ArticleCard from '../../../components/ArticleCard.astro';
import { getCollection } from 'astro:content';
import { t, type Locale } from '../../../i18n/translations';

const locale: Locale = 'nl';
const strings = t(locale);

const categoryLabels: Record<string, string> = {
    binnenland: 'Binnenland', buitenland: 'Buitenland', tech: 'Tech', sport: 'Sport', column: 'Column',
};

export async function getStaticPaths() {
    const categories = ['binnenland', 'buitenland', 'tech', 'sport', 'column'];
    return categories.map(cat => ({ params: { category: cat } }));
}

const { category } = Astro.params;
const label = categoryLabels[category!] || category;

const allArticles = await getCollection('articles', ({ data }) => data.lang === 'nl');
const articles = allArticles
    .filter(a => a.data.category === category)
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout title={label}>
    <Header slot="header" locale={locale} currentPath={`/nl/rubriek/${category}`} />

    <div style="max-width:1200px;margin:0 auto;padding:32px 24px 60px">
        <div class="category-header">
            <h1>{label}</h1>
            <p>{articles.length} {articles.length === 1 ? strings.categoryPage.article : strings.categoryPage.articles}</p>
        </div>

        {articles.length > 0 ? (
            <div class="category-articles">
                <div class="articles-grid">
                    {articles.map(article => (
                        <ArticleCard
                            title={article.data.title}
                            slug={article.slug}
                            category={article.data.category}
                            date={article.data.date}
                            excerpt={article.data.excerpt}
                            image={article.data.image}
                            readTime={article.data.readTime}
                            locale={locale}
                        />
                    ))}
                </div>
            </div>
        ) : (
            <div class="empty-state">
                <h2>{strings.categoryPage.empty.replace('{category}', label.toLowerCase())}</h2>
                <p>{strings.categoryPage.addArticle} <a href={`${import.meta.env.BASE_URL}admin/`}>/admin</a></p>
            </div>
        )}
    </div>

    <Footer slot="footer" locale={locale} />
</BaseLayout>
