---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { t, type Locale } from '../i18n/translations';

const locale: Locale = 'en';
const strings = t(locale);
const currentPath = '/advertise';
---

<BaseLayout title="Advertise — SNIKSNAK">
    <Header slot="header" locale={locale} currentPath={currentPath} />

    <div class="content-page">
        <div class="content-page-inner">
            <h1>Advertise</h1>
            <p class="standfirst">Reach the people who matter. Or at least the people who are killing time.</p>

            <div class="content-page-body">
                <p>SNIKSNAK offers a unique advertising opportunity: a highly engaged audience of people who actively chose to read satire news. These are discerning consumers with a refined sense of humor and, presumably, disposable income (we have not verified this).</p>

                <h2>Our Audience</h2>
                <ul>
                    <li>Readers who appreciate the fine line between news and entertainment</li>
                    <li>People who share articles in group chats to appear intellectually superior</li>
                    <li>Anyone who Googled "funny Dutch news" and ended up here by accident</li>
                </ul>

                <h2>Ad Formats</h2>
                <div class="ad-formats">
                    <div class="ad-format">
                        <h3>Banner Ad</h3>
                        <p>A banner at the top of the page. Visible for approximately 0.3 seconds before the user scrolls past it. Pricing: available upon request, meaning we'll make up a number based on your company's logo.</p>
                    </div>
                    <div class="ad-format">
                        <h3>Sponsored Article</h3>
                        <p>Your product woven into a satirical article about something completely unrelated. Example: "In other news, the new iPhone was launched today. Meanwhile, in Utrecht, a man was arrested for feeding pigeons interpretive poetry." Pricing: we accept sandwiches.</p>
                    </div>
                    <div class="ad-format">
                        <h3>Newsletter Sponsorship</h3>
                        <p>Your brand mentioned in our newsletter that nobody subscribes to. This is technically an advertising opportunity in the same way that a billboard in the Mariana Trench is an advertising opportunity.</p>
                    </div>
                </div>

                <h2>Why SNIKSNAK?</h2>
                <p>Because your brand deserves to be associated with something slightly confusing. Because traditional advertising is boring and you want to stand out. Because our readers are the kind of people who will buy things advertised ironically, then tell their friends about it unironically.</p>

                <p>For inquiries, contact <strong>ads@sniksnak.nl</strong>. Please include your budget, timeline, and a brief explanation of why you think this is a good idea.</p>
            </div>
        </div>
    </div>

    <Footer slot="footer" locale={locale} />
</BaseLayout>

<style>
    .content-page { max-width: 720px; margin: 0 auto; padding: 48px 24px 80px; }
    .content-page h1 { font-size: 36px; font-weight: 800; margin-bottom: 8px; }
    .standfirst { font-size: 18px; color: var(--color-text-secondary); margin-bottom: 40px; line-height: 1.6; }
    .content-page-body h2 { font-size: 22px; font-weight: 700; margin: 32px 0 12px; }
    .content-page-body h3 { font-size: 18px; font-weight: 700; margin: 16px 0 8px; }
    .content-page-body p { font-size: 16px; line-height: 1.8; color: var(--color-text-secondary); margin-bottom: 20px; }
    .content-page-body ul { margin: 16px 0 24px; padding-left: 24px; }
    .content-page-body li { font-size: 16px; line-height: 1.8; color: var(--color-text-secondary); margin-bottom: 8px; }
    .ad-formats { display: flex; flex-direction: column; gap: 24px; margin: 24px 0; }
    .ad-format { background: var(--color-border-light); padding: 24px; border-radius: var(--radius-lg); }
</style>
